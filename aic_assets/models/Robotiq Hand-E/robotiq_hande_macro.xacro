<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:include filename="$(find aic_assets)/models/Robotiq Hand-E/robotiq_hande.ros2_control.xacro"/>

  <xacro:macro name="robotiq_hande" params="name tf_prefix grip_pos_min grip_pos_max grip_vel_max grip_effort_min grip_effort_max initial_pos">

    <xacro:robotiq_hande_ros2_control
      name="${name}"
      tf_prefix="${tf_prefix}"
      grip_pos_min="${grip_pos_min}"
      grip_pos_max="${grip_pos_max}"
      grip_effort_min="${grip_effort_min}"
      grip_effort_max="${grip_effort_max}"
      initial_pos="${initial_pos}"
    />

    <xacro:property name="gripper_jaw_offset" value="0.025"/>

    <link name="${tf_prefix}hande_base_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.1" ixy="0" ixz="0"
                 iyy="0.1" iyz="0"
                 izz="0.1"/>
      </inertial>

      <visual name="hande_base_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aic_assets/models/Robotiq Hand-E/hande_base_visual.glb"/>
        </geometry>
      </visual>

      <collision name="body_collider_cylinder">
        <origin xyz="0.0 0.0 0.06855" rpy="3.141593 0.0 1.570796"/>
        <geometry>
          <cylinder radius="0.038" length="0.1131"/>
        </geometry>
      </collision>

      <collision name="cylinder003_collider_cylinder">
        <origin xyz="0.0 0.0 0.006" rpy="0.0 0.0 0.0"/>
        <geometry>
          <cylinder radius="0.043" length="0.012"/>
        </geometry>
      </collision>

    </link>

    <link name="${tf_prefix}hande_finger_link_l">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.001"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.00009" iyz="0"
                 izz="0.00003"/>
      </inertial>

      <visual name="hande_finger_visual">
        <origin xyz="${-gripper_jaw_offset} 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aic_assets/models/Robotiq Hand-E/hande_finger_visual.glb"/>
        </geometry>
      </visual>

      <collision name="finger_collider_box">
        <origin xyz="${-gripper_jaw_offset + 0.032595} -0.00001 0.138138" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.007839 0.021 0.028622"/>
        </geometry>
      </collision>

      <collision name="finger_collider_box001">
        <origin xyz="${-gripper_jaw_offset + 0.028} -0.00001 0.16145" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.006 0.021 0.021498"/>
        </geometry>
      </collision>

      <collision name="finger_collider_box002">
        <origin xyz="${-gripper_jaw_offset + 0.014354} -0.015 0.124725" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.044319 0.0075 0.003949"/>
        </geometry>
      </collision>

      <collision name="finger_collider_box003">
        <origin xyz="${-gripper_jaw_offset + 0.027046} -0.00954 0.129064" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.017387 0.018419 0.009271"/>
        </geometry>
      </collision>
    </link>

    <link name="${tf_prefix}hande_finger_link_r">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.001"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.00009" iyz="0"
                 izz="0.00003"/>
      </inertial>

      <visual name="hande_finger_visual">
        <origin xyz="${gripper_jaw_offset} 0 0" rpy="0 0 3.14157"/>
        <geometry>
          <mesh filename="package://aic_assets/models/Robotiq Hand-E/hande_finger_visual.glb"/>
        </geometry>
      </visual>

      <collision name="finger_collider_box">
        <origin xyz="${gripper_jaw_offset - 0.032595} -0.00001 0.138138" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.007839 0.021 0.028622"/>
        </geometry>
      </collision>

      <collision name="finger_collider_box001">
        <origin xyz="${gripper_jaw_offset - 0.028} -0.00001 0.16145" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.006 0.021 0.021498"/>
        </geometry>
      </collision>

      <collision name="finger_collider_box002">
        <origin xyz="${gripper_jaw_offset - 0.014354} -0.015 0.124725" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.044319 0.0075 0.003949"/>
        </geometry>
      </collision>

      <collision name="finger_collider_box003">
        <origin xyz="${gripper_jaw_offset - 0.027046} -0.00954 0.129064" rpy="0.0 0.0 0.0"/>
        <geometry>
          <box size="0.017387 0.018419 0.009271"/>
        </geometry>
      </collision>
    </link>

    <joint name="${tf_prefix}left_finger_joint" type="prismatic">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${tf_prefix}hande_base_link"/>
      <child link="${tf_prefix}hande_finger_link_l"/>
      <axis xyz="1 0 0"/>
      <limit effort="${grip_effort_max}" lower="${grip_pos_min}" upper="${grip_pos_max}" velocity="${grip_vel_max}"/>
    </joint>

    <joint name="${tf_prefix}right_finger_joint" type="prismatic">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${tf_prefix}hande_base_link"/>
      <child link="${tf_prefix}hande_finger_link_r"/>
      <axis xyz="-1 0 0"/>
      <limit effort="${grip_effort_max}" lower="${grip_pos_min}" upper="${grip_pos_max}" velocity="${grip_vel_max}"/>
      <mimic joint="${tf_prefix}left_finger_joint" multiplier="1" offset="0"/>
    </joint>

    <link name="${tf_prefix}tcp"/>

    <joint name="${tf_prefix}attach_tool_frame" type="fixed">
      <origin xyz="0 0 0.172" rpy="0 0 0"/>
      <parent link="${tf_prefix}hande_base_link"/>
      <child link="${tf_prefix}tcp"/>
    </joint>

  </xacro:macro>
</robot>
